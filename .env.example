# ----------------------------------------------------------------------------
# Token Saver Router — local development environment.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ----------------------------------------------------------------------------

# Server bind
TOKEN_SAVER_HOST=0.0.0.0
TOKEN_SAVER_PORT=8787
TOKEN_SAVER_WORKERS=1
TOKEN_SAVER_LOG_LEVEL=INFO

# Storage connections (docker-compose service names by default).
TOKEN_SAVER_REDIS_URL=redis://redis:6379/0
TOKEN_SAVER_MONGO_URL=mongodb://token_saver:token_saver@mongo:27017/token_saver?authSource=admin
TOKEN_SAVER_MONGO_DB_NAME=token_saver

# Master key for AES-GCM encryption of provider credentials.
# Generate with: python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
TOKEN_SAVER_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Auth / rate limit
TOKEN_SAVER_SESSION_TTL_SECONDS=3600
TOKEN_SAVER_RATE_LIMIT_PER_MINUTE=60

# CCR-lite TTLs
TOKEN_SAVER_CCR_REDIS_TTL_SECONDS=300
TOKEN_SAVER_CCR_MONGO_TTL_DAYS=30

# Provider registry
TOKEN_SAVER_PROVIDER_MODELS_CACHE_TTL_SECONDS=3600
TOKEN_SAVER_PROVIDER_HEALTH_TTL_SECONDS=30
TOKEN_SAVER_PROVIDER_REQUEST_TIMEOUT_SECONDS=60

# One-time admin bootstrap (consumed by TASK-002-4 admin seed script).
# Set strong values; rotate after first login.
TOKEN_SAVER_ADMIN_EMAIL=admin@example.com
TOKEN_SAVER_ADMIN_PASSWORD=changeme-please